    },
    {
      "parameters": {
        "content": "## File Validation\n\nSupported formats:\n\u2713 DOCX (Microsoft Word)\n\u2713 PDF (Portable Document)\n\u2713 TXT (Plain Text)\n\u2713 MD (Markdown)\n\nInvalid files are rejected with 400 error response.",
        "height": 200,
        "width": 300,
        "color": 5
      },
      "id": "081a5593-8b6e-4f36-a24f-71e986211ade",
